{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/baumar73/j-stack-skill-system/sources/osint-sources.schema.json",
  "title": "J-Stack OSINT Source Atlas entry",
  "type": "object",
  "required": [
    "version",
    "last_reviewed",
    "scope_note",
    "sources"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string"
    },
    "last_reviewed": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "scope_note": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "category",
          "jurisdiction",
          "url",
          "access",
          "automation",
          "license_tos",
          "data_types",
          "best_for",
          "caution",
          "personal_data_risk",
          "evidence_weight",
          "citation_note",
          "tags"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "jurisdiction": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "access": {
            "type": "string",
            "enum": [
              "free-public",
              "free-registration",
              "api-available",
              "paid-or-limited",
              "mixed",
              "restricted"
            ]
          },
          "automation": {
            "type": "string",
            "enum": [
              "manual-first",
              "api-preferred",
              "bulk-download-ok",
              "no-bulk",
              "do-not-automate"
            ]
          },
          "license_tos": {
            "type": "string"
          },
          "data_types": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "best_for": {
            "type": "string"
          },
          "caution": {
            "type": "string"
          },
          "personal_data_risk": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "evidence_weight": {
            "type": "string",
            "enum": [
              "primary",
              "secondary",
              "index",
              "lead-only"
            ]
          },
          "citation_note": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]*$"
            },
            "minItems": 1
          }
        }
      }
    }
  }
}
